{
  "enabled": true,
  "name": "Pre-commit Validation",
  "description": "Runs lint and tests before allowing commits to ensure code quality and prevent CI/CD failures",
  "version": "1",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "runCommand",
    "command": "npm run lint && npm run test"
  },
  "workspaceFolderName": "kiro",
  "shortName": "pre-commit-validation"
}