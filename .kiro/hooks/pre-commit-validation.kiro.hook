{
  "enabled": false,
  "name": "Pre-commit Validation",
  "description": "Runs lint, tests and build before allowing commits to ensure code quality and prevent CI/CD failures",
  "version": "1",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "askAgent",
    "prompt": "Before committing any changes, always run 'npm run lint', 'npm run test', and 'npm run build' to ensure the code passes all checks and won't break in GitHub Actions. Only proceed with git commit if all three commands succeed."
  },
  "workspaceFolderName": "kiro",
  "shortName": "pre-commit-validation"
}

// TEMPORARIAMENTE DESABILITADO - Para economizar tokens
// Para reativar: mude "enabled": false para "enabled": true